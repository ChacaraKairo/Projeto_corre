{
  "expo": {
    "name": "Korre",
    "slug": "korre",
    "version": "1.2.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "korre",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chacara.korre",
      "buildNumber": "1.2.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "O KORRE usa Face ID para proteger o acesso aos seus dados locais.",
        "NSPhotoLibraryUsageDescription": "O KORRE acessa suas fotos apenas quando você escolhe uma imagem para o perfil.",
        "NSCameraUsageDescription": "O KORRE usa a câmera apenas quando você escolhe tirar uma foto de perfil."
      }
    },
    "android": {
      "package": "korre_app.gestao.korucompany",
      "versionCode": 10,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground-safe.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome-safe.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/images/splash-logo.png"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O KORRE acessa suas fotos apenas quando você escolhe uma imagem para o perfil.",
          "cameraPermission": "O KORRE usa a câmera apenas quando você escolhe tirar uma foto de perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00C853",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "expo-local-authentication",
      "expo-document-picker",
      "expo-sqlite",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "koru-company",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9eb15bea-8b0f-48b5-9458-b02c47f56ef8"
      }
    }
  }
}
